# ── Database ──────────────────────────────────────────────────────────────────
HOST=localhost
USER=ecijacomarca_user
PASSWORD=change_me_strong_password
DATABASE=ecijacomarca

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_KEY

# ── Storage ───────────────────────────────────────────────────────────────────
# Path where uploaded media files are stored
# Windows: C:\EcijaComarca\Media   Linux: /opt/ecijacomarca/media
MEDIA_PATH=C:\EcijaComarca\Media

# Maximum upload size in bytes (default: 50 GB)
# 50 GB = 53687091200
MAX_FILE_SIZE=53687091200

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Updates (optional) ────────────────────────────────────────────────────────
# URL of a JSON manifest to check for remote updates.
# Leave blank to use only local packages in the updates/ folder.
# Manifest format: { "version": "2.1.0", "changes": ["Fix X"], "download": "https://...", "filename": "release-2.1.0.zip" }
UPDATE_MANIFEST_URL=
